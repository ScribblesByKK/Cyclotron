# Set default behavior to automatically normalize line endings to CRLF (Windows-style)
* text=auto eol=crlf

# Explicitly declare text files you want to always be normalized and converted to CRLF
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.config text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.snk binary
